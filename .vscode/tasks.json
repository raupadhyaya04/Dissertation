{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Stata: Run Full Pipeline (main.do)",
      "type": "shell",
      "command": "/Applications/Stata/StataMP.app/Contents/MacOS/stata-mp",
      "args": [
        "-b",
        "do",
        "${workspaceFolder}/Final Project/main.do"
      ],
      "options": {
        "cwd": "${workspaceFolder}/Final Project"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Stata: Step 1 – Clean Data (1_clean_data.do)",
      "type": "shell",
      "command": "/Applications/Stata/StataMP.app/Contents/MacOS/stata-mp",
      "args": [
        "-b",
        "do",
        "${workspaceFolder}/Final Project/1_clean_data.do"
      ],
      "options": {
        "cwd": "${workspaceFolder}/Final Project"
      },
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Stata: Step 2 – Nonlinear Analysis (2_nonlinear_analysis.do)",
      "type": "shell",
      "command": "/Applications/Stata/StataMP.app/Contents/MacOS/stata-mp",
      "args": [
        "-b",
        "do",
        "${workspaceFolder}/Final Project/2_nonlinear_analysis.do"
      ],
      "options": {
        "cwd": "${workspaceFolder}/Final Project"
      },
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Stata: View Log (main.log)",
      "type": "shell",
      "command": "tail",
      "args": ["-f", "${workspaceFolder}/Final Project/main.log"],
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
